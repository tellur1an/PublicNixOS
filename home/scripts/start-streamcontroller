#!/usr/bin/env bash
set -euo pipefail

RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
WAYLAND_SOCKET="${WAYLAND_DISPLAY:-wayland-0}"
LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/streamcontroller"
LOG_FILE="$LOG_DIR/start.log"

mkdir -p "$LOG_DIR"

log() {
  printf '[%(%F %T)T] %s\n' -1 "$*" >>"$LOG_FILE"
}

ui_running() {
  pgrep -u "$USER" -a -f \
    '(^|/)streamcontroller( |$)|streamcontroller-wrapped' \
    >/dev/null 2>&1
}

for _ in $(seq 1 100); do
  if [[ -S "$RUNTIME_DIR/$WAYLAND_SOCKET" ]]; then
    break
  fi
  sleep 0.2
done

if [[ ! -S "$RUNTIME_DIR/$WAYLAND_SOCKET" ]]; then
  log "timed out waiting for $RUNTIME_DIR/$WAYLAND_SOCKET"
  exit 1
fi

for _ in $(seq 1 100); do
  if [[ -n "${DBUS_SESSION_BUS_ADDRESS:-}" || -S "$RUNTIME_DIR/bus" ]]; then
    break
  fi
  sleep 0.2
done

export XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-wayland}"
export QT_QPA_PLATFORM=wayland
export DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=$RUNTIME_DIR/bus}"

if ui_running; then
  log "ui already running; skipping launch"
  exit 0
fi

# Native nixpkgs StreamController (was the com.core447.StreamController
# flatpak). Resolve from PATH, falling back to the system profile in case the
# compositor launched us with a minimal PATH. It keeps using the same data dir
# (~/.var/app/com.core447.StreamController/data) the flatpak populated.
SC="$(command -v streamcontroller || true)"
: "${SC:=/run/current-system/sw/bin/streamcontroller}"

if [[ ! -x "$SC" ]]; then
  log "streamcontroller binary not found (looked at '$SC')"
  exit 1
fi

log "launching StreamController via $SC"
nohup "$SC" -b >>"$LOG_FILE" 2>&1 &
