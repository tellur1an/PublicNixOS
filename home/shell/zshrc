# ytplay — ported from fish (mpv + yt-dlp with youtube cookies)
ytplay() {
    mpv --ytdl-raw-options="cookies=/home/username/youtube-cookies.txt,extractor-args=youtube:player_client=web_embedded" \
        "ytdl://ytsearch:$*"
}

# mkcd — make dir and cd into it
mkcd() { mkdir -p "$1" && cd "$1"; }

# extract — universal archive extractor
extract() {
    if [[ -f "$1" ]]; then
        case "$1" in
            *.tar.bz2) tar xjf "$1"   ;;
            *.tar.gz)  tar xzf "$1"   ;;
            *.tar.xz)  tar xJf "$1"   ;;
            *.tar.zst) tar --zstd -xf "$1" ;;
            *.bz2)     bunzip2 "$1"   ;;
            *.gz)      gunzip "$1"    ;;
            *.tar)     tar xf "$1"    ;;
            *.tbz2)    tar xjf "$1"   ;;
            *.tgz)     tar xzf "$1"   ;;
            *.zip)     unzip "$1"     ;;
            *.Z)       uncompress "$1";;
            *.7z)      7z x "$1"      ;;
            *.zst)     unzstd "$1"    ;;
            *.rar)     unrar x "$1"   ;;
            *)         echo "Unknown archive type: $1" ;;
        esac
    else
        echo "'$1' is not a file"
    fi
}

# fcd — fzf directory picker + cd
fcd() {
    local dir
    dir=$(fd --type dir --hidden --exclude .git . "${1:-.}" | \
          fzf --preview 'eza --tree --color=always {} | head -40') && cd "$dir"
}

# fopen — fzf file picker + $EDITOR
fopen() {
    local file
    file=$(fd --type file --hidden --exclude .git . "${1:-.}" | \
           fzf --preview 'bat --style=numbers --color=always --line-range :300 {}') && \
    ${EDITOR:-nano} "$file"
}

# fkill — fzf process killer
fkill() {
    local pid
    pid=$(procs 2>/dev/null || ps aux | fzf --header-lines=1 | awk '{print $2}') && kill -${1:-9} "$pid"
}

# gfb — fzf git branch switcher
gfb() {
    local branch
    branch=$(git branch -a | grep -v HEAD | fzf --preview 'git log --oneline --graph --color=always $(echo {} | sed "s/.* //" | sed "s#remotes/[^/]*/##")' | \
             sed 's/.* //' | sed 's#remotes/[^/]*/##') && git checkout "$branch"
}

# gfl — fzf git log navigator (show commit, can checkout)
gfl() {
    git log --oneline --graph --decorate --color=always | \
    fzf --ansi --no-sort --preview 'echo {} | grep -o "[a-f0-9]\{7,\}" | head -1 | xargs git show --color=always' \
        --bind 'enter:execute(echo {} | grep -o "[a-f0-9]\{7,\}" | head -1 | xargs git show | bat -l diff)'
}

# senv — fzf env var search
senv() {
    env | sort | fzf --preview 'echo {}'
}

# tldrfzf — browse tldr pages with fzf
tldrfzf() {
    tldr --list 2>/dev/null | fzf --preview 'tldr {}' --preview-window=right:70% | xargs tldr
}

# glow_fzf — browse markdown files with glow
if command -v glow &>/dev/null; then
    glowf() {
        fd --type file -e md | fzf --preview 'glow {}' | xargs glow -p
    }
fi

# bash_source — run bash scripts without rewriting them
bash_source() { emulate -L bash; source "$1"; }

# nnn with cd-on-quit (like fish's integration)
