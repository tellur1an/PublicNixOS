# nixpush [commit message]  — stage + commit any changes, then push to origin + github-private
nixpush() {
  local msg="${*:-config update $(date +%Y-%m-%dT%H:%M)}"
  git -C ~/myflake add -A
  if ! git -C ~/myflake diff --cached --quiet; then
    git -C ~/myflake commit -m "$msg" || return 1
  fi
  git -C ~/myflake push origin && git -C ~/myflake push github-private
}
alias nixswitch='sudo nixos-rebuild switch --flake ~/myflake\#nixos'
alias nixupdate='nix flake update --flake ~/myflake && sudo nixos-rebuild switch --flake ~/myflake\#nixos'

