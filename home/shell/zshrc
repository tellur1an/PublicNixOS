# ╔══════════════════════════════════════════════════════════════╗
# ║                   ~/.zshrc — fish refugee                   ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Performance: skip for non-interactive ────────────────────────────────────
[[ $- != *i* ]] && return

# ── Wayland session vars (inherit from systemd if WM keybind launched early) ─
if [[ -z "$WAYLAND_DISPLAY" ]]; then
  _wl=$(systemctl --user show-environment 2>/dev/null | grep '^WAYLAND_DISPLAY=' | cut -d= -f2)
  [[ -n "$_wl" ]] && export WAYLAND_DISPLAY=$_wl
  unset _wl
fi

# ── Zinit bootstrap ──────────────────────────────────────────────────────────
ZINIT_HOME="${XDG_DATA_HOME:-$HOME/.local/share}/zinit/zinit.git"
if [[ ! -d "$ZINIT_HOME" ]]; then
    mkdir -p "$(dirname "$ZINIT_HOME")"
    git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi
source "${ZINIT_HOME}/zinit.zsh"
autoload -Uz _zinit
(( ${+_comps} )) && _comps[zinit]=_zinit

# ── Plugins (order matters) — skip in non-TTY contexts (e.g. topgrade) ───────
if [[ -t 0 ]]; then

# Syntax highlighting FIRST (must be before other plugins that set widgets)
zinit light zdharma-continuum/fast-syntax-highlighting

# Fish-like ghost-text autosuggestions
zinit light zsh-users/zsh-autosuggestions

# fzf-powered tab completion menu (closest to fish's tab UI)
zinit light Aloxaf/fzf-tab

# Extra community completions
zinit light zsh-users/zsh-completions

# Fish-like history substring search (up/down arrows)
zinit light zsh-users/zsh-history-substring-search

# Fish-like abbreviations that expand on space
zinit light olets/zsh-abbr

# Auto-close/delete brackets, quotes (fish autopair equivalent)
zinit light hlissner/zsh-autopair

# cd to frecent dirs (like fish's cdh). zoxide provides `z`/`zi`.
# zinit light agkozak/zsh-z

# fzf-powered interactive git UI (stage hunks, log browser, diff picker, stash)
zinit light wfxr/forgit

# reminds you to use alias when you type the full command
zinit light MichaelAquilina/zsh-you-should-use

# updates terminal tab/window title on cd and command run
zinit light jreese/zsh-titles


# jump back to named parent dir: inside ~/a/b/c/d, `bd b` → ~/a/b
zinit light Tarrasch/zsh-bd

# separate history per directory (toggle with ^G)
zinit light jimhester/per-directory-history

fi # [[ -t 0 ]]

# ── Completion system ────────────────────────────────────────────────────────
autoload -Uz compinit
# Only rebuild cache once per day
if [[ -n ${ZDOTDIR:-$HOME}/.zcompdump(#qN.mh+24) ]]; then
    compinit -u
else
    compinit -uC
fi

zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}' 'r:|=*' 'l:|=* r:|=*'
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
zstyle ':completion:*:descriptions' format '[%d]'
zstyle ':completion:*:warnings' format '%F{red}no matches%f'
zstyle ':completion:*:git-checkout:*' sort false
zstyle ':completion:*' group-name ''
zstyle ':completion:*' squeeze-slashes true
zstyle ':completion::complete:*' use-cache on
zstyle ':completion::complete:*' cache-path "${XDG_CACHE_HOME:-$HOME/.cache}/zsh/compcache"

# fzf-tab: use fzf for all tab completions
zstyle ':fzf-tab:complete:cd:*'         fzf-preview 'eza --color=always --icons $realpath 2>/dev/null || ls --color=always $realpath'
zstyle ':fzf-tab:complete:__zoxide_z:*' fzf-preview 'eza --color=always --icons $realpath 2>/dev/null'
zstyle ':fzf-tab:complete:kill:*'       fzf-preview 'ps --pid=$word -o cmd --no-header -w -w'
zstyle ':fzf-tab:complete:(-command-|-parameter-|-brace-parameter-|export|unset|expand):*' \
    fzf-preview 'echo ${(P)word}'
zstyle ':fzf-tab:*' switch-group '<' '>'
zstyle ':fzf-tab:*' fzf-flags --height=50% --layout=reverse
zstyle ':fzf-tab:*' continuous-trigger '/'   # keep completing path segments

# ── History ───────────────────────────────────────────────────────────────────
HISTFILE="${XDG_DATA_HOME:-$HOME/.local/share}/zsh/history"
mkdir -p "$(dirname "$HISTFILE")"
HISTSIZE=100000
SAVEHIST=100000

setopt SHARE_HISTORY          # sync across sessions (like fish)
setopt HIST_IGNORE_DUPS       # no consecutive dupes
setopt HIST_IGNORE_ALL_DUPS   # remove older dupe if same cmd entered
setopt HIST_IGNORE_SPACE      # leading space = no history (privacy)
setopt HIST_REDUCE_BLANKS
setopt EXTENDED_HISTORY       # store timestamps
setopt HIST_VERIFY            # expand history before executing

# ── Atuin (superpowered history, replaces Ctrl-R) ────────────────────────────
if [[ -t 0 ]] && command -v atuin &>/dev/null; then
    eval "$(atuin init zsh --disable-up-arrow)"
    # Ctrl-R → atuin interactive search
    bindkey '^r' atuin-search
fi

# ── Directory behavior ────────────────────────────────────────────────────────
setopt AUTO_CD                # type dir name alone = cd (like fish)
setopt AUTO_PUSHD             # cd pushes to dir stack
setopt PUSHD_IGNORE_DUPS
setopt PUSHD_SILENT
setopt CDABLE_VARS            # cd to named directories

# Zoxide (better z — frecency-based cd)
if command -v zoxide &>/dev/null; then
    eval "$(zoxide init zsh --no-cmd)"
    function z() { __zoxide_z "$@" }
    function zoi() { __zoxide_zi "$@" }
    (( ${+functions[compdef]} )) && compdef __zoxide_z_complete z
fi

# ── Misc shell options ────────────────────────────────────────────────────────
setopt CORRECT                # suggest corrections for commands
setopt CORRECT_ALL            # suggest corrections for args too
setopt INTERACTIVE_COMMENTS   # allow # comments in interactive shell
setopt NO_BEEP                # no bell
setopt COMBINING_CHARS        # handle unicode combining chars
setopt RC_QUOTES              # '' = literal ' inside single-quoted strings
setopt LONG_LIST_JOBS         # verbose job listings
setopt NOTIFY                 # report bg job status immediately
setopt MULTIOS                # multiple redirections
setopt EXTENDED_GLOB          # #, ~, ^ in patterns
setopt GLOB_DOTS              # dotfiles in globs without leading dot
setopt NULL_GLOB              # no error if glob matches nothing
unsetopt FLOW_CONTROL         # disable Ctrl-S/Ctrl-Q freeze

